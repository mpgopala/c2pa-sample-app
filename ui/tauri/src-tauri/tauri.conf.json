{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "C2PA Tool",
  "version": "0.1.0",
  "identifier": "com.c2pa.tool",
  "build": {
    "frontendDist": "../"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "C2PA Tool",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "label": "main"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
